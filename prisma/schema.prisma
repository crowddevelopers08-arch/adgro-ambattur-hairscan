generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Scan {
  id             Int      @id @default(autoincrement())
  name           String
  phone          String
  location       String   @default("")
  problem        String
  imageData      String
  formName       String   @default("website leads")
  sourceUrl      String   @default("")
  telecrmStatus  String   @default("not_synced")
  telecrmLeadIds String   @default("")
  telecrmError   String   @default("")
  createdAt      DateTime @default(now())
}
